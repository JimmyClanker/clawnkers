# Required
EXA_API_KEY=your-exa-api-key
SIGNAL_INGEST_KEY=a-strong-random-key-at-least-32-chars

# Optional — Nevermined payment gating
NVM_API_KEY=your-nevermined-api-key
NVM_PLAN_ID=your-plan-id
NVM_AGENT_ID=your-agent-id
NVM_ENV=production

# Optional — MCP auth (if set, clients need x-mcp-key header)
MCP_AUTH_KEY=your-mcp-auth-key

# Optional — xAI API key for Grok 4.20 analysis (Alpha Scanner full reports)
XAI_API_KEY=your-xai-api-key

# Optional — auth key for paid/full alpha reports (required only if XAI_API_KEY is set and you want to gate /alpha)
ALPHA_AUTH_KEY=your-alpha-auth-key

# Optional — SQLite path (default: ./data/signals.db)
DB_PATH=./data/signals.db

# Optional — Port (default: 4021)
PORT=4021
